# GEMINI_API_KEY is the only var that's actually required — internal/config
# fails fast without it. Everything DB-related below has a working local
# default (localhost:5432/agentic_desk, trust auth) if left unset.
GEMINI_API_KEY=

# Option A: one connection string. Wins over every DB_* var below if set.
DATABASE_URL=postgres://YOUR_USER@localhost:5432/agentic_desk

# Option B: split fields (used only when DATABASE_URL above is unset/empty).
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=YOUR_USER
# DB_PASSWORD=
# DB_NAME=agentic_desk
# DB_SSL_MODE=disable
# DB_MAX_OPEN_CONNS=20
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=1h
# DB_CONN_MAX_IDLE_TIME=10m
